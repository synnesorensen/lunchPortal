# Copy to .env — never commit .env. Prefer AWS SSO / aws configure over long-lived keys.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Terraform / app (set after first apply or use existing dev values)
TF_VAR_project_name=newlunchapp
TF_VAR_dynamodb_table_name=newlunchapp-data
TF_VAR_cognito_user_pool_id=
TF_VAR_cognito_app_client_id=

# Client (Vite)
VITE_API_URL=http://localhost:3000
